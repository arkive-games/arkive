# Root of the raw UE5 game export consumed by the tools (Perforce-managed later).
# Per-machine path — set this to wherever the game export lives on your PC.
RAW_DATA_PATH=G:/NCSoft/Export/Exports/AION2/Content

# Sibling frontend repo. Defaults to ../frontend relative to tools/; set only if
# your workspace layout differs.
# FRONTEND_ROOT=G:/NCSoft/aion2-map/frontend

# Output repos (served over HTTP)
DATA_OUTPUT_PATH=G:/NCSoft/aion2-map/data
IMAGES_OUTPUT_PATH=G:/NCSoft/aion2-map/images

# Backend login used by the upload/sync tools (tools/aion2/tools/common/auth.py).
AION2_BACKEND_USERNAME=you@example.com
AION2_BACKEND_PASSWORD=change-me
