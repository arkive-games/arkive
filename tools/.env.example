# Per-machine paths. All of these are REQUIRED by the tool that consumes them —
# there are no hardcoded fallbacks; a missing variable raises at run time.
# Copy this file to tools/.env and fill in your local paths.

# --- AION2 ---

# Root of the raw UE5 game export consumed by the tools (Perforce-managed later).
RAW_DATA_PATH=G:/NCSoft/Export/Exports/AION2/Content

# Monorepo frontend/ workspace. Defaults to <monorepo>/frontend; set only if
# your checkout layout differs.
# FRONTEND_ROOT=E:/arkive-games/arkive/frontend

# Output repos the frontend reads over HTTP (siblings of this monorepo).
AION2_DATA_OUT=E:/arkive-games/data-aion2
AION2_RES_OUT=E:/arkive-games/resource-aion2

# Only for the legacy one-off scripts (items/parse.py, pets/*): the
# pre-monorepo export root (old layout, UI/ directly under it) and the pets
# screenshot folder. Leave unset unless you run those scripts.
# AION2_LEGACY_EXPORT_ROOT=G:/NCSoft/Export
# AION2_PETS_DIR=G:/NCSoft/pets

# Backend login used by the upload/sync tools (tools/aion2/tools/common/auth.py).
AION2_BACKEND_USERNAME=you@example.com
AION2_BACKEND_PASSWORD=change-me

# --- Palworld ---

# Raw UE export root (…/Content/Pal) consumed by the palworld pipelines.
PALWORLD_RAW=E:/SteamLibrary/steamapps/common/Palworld/Exports/Pal/Content/Pal
# Output repos the frontend reads over HTTP (siblings of this monorepo).
PALWORLD_DATA_OUT=E:/arkive-games/data-palworld
PALWORLD_RES_OUT=E:/arkive-games/resource-palworld
