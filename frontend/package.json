{
  "name": "gamemap-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:aion2": "pnpm --filter aion2 dev",
    "build:aion2": "pnpm --filter aion2 build",
    "lint:aion2": "pnpm --filter aion2 lint",
    "preview:aion2": "pnpm --filter aion2 preview",
    "e2e:aion2": "pnpm --filter aion2 exec playwright test",
    "dev:palworld": "pnpm --filter palworld dev",
    "build:palworld": "pnpm --filter palworld build",
    "lint:palworld": "pnpm --filter palworld lint",
    "preview:palworld": "pnpm --filter palworld preview",
    "e2e:palworld": "pnpm --filter palworld e2e",
    "dev:meta": "pnpm --filter meta dev",
    "build:meta": "pnpm --filter meta build",
    "lint:meta": "pnpm --filter meta lint",
    "preview:meta": "pnpm --filter meta preview",
    "test": "vitest run",
    "check:engine": "grep -rn --include=*.ts --include=*.tsx -P \"react-i18next|@tanstack/react-router|import\\.meta\\.env|localStorage|@/|[\\x22\\x27\\x60]UI/\" packages/map-engine/src && exit 1 || exit 0",
    "check:shell": "grep -rn --include=*.ts --include=*.tsx -P \"i18next|useTranslation|react-router|import\\.meta\\.env|localStorage|fetch\\(|@/\" packages/map-shell/src && exit 1 || exit 0",
    "validate-data": "node packages/data-contract/scripts/validate-data.ts"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@7.2.2"
    }
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
