# Copy to frontend/.env. No secrets here, but .env is gitignored so each env sets its own.

# CDN base for legacy assets.
VITE_CDN_BASE_URL=http://cdn.tc-imba.com/

# Backend API base. Dev: local backend (default port 9000).
VITE_API_BASE_URL=http://localhost:9000/

; VITE_STATIC_BASE_URL=/

; Base URL for the `resource` repo (game UI/Map webp assets, served under UI/).
; Prod only: a host serving the resource repo's UI/. Leave unset in dev — Vite
; proxies /UI to the local ../resource/UI (see vite.config.ts).
; VITE_RESOURCE_BASE_URL=https://cdn.example.com/resource

; Base URL for the `data` repo (parsed game dataset + game-data locales).
; Prod only: a host serving the data repo root (so that <base>/maps.yaml,
; <base>/markers/<map>.yaml, <base>/locales/<lng>/... resolve). Leave unset in
; dev — Vite serves the local ../data at /data (see vite.config.ts).
; VITE_DATA_BASE_URL=https://cdn.example.com/data

VITE_REGION=CHINA

; Site footer (shared SiteFooter component). All optional — defaults are the
; Arkive Games main site, GitHub org, and Shanghai ICP record.
; VITE_HOME_URL=https://tc-imba.com
; VITE_GITHUB_URL=https://github.com/arkive-games
; VITE_ICP_BEIAN=沪ICP备2025152827号-1
