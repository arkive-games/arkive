# Copy to backend/.env and fill in real values. .env is gitignored — never commit secrets.

# --- PostgreSQL ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_PASSWORD=change-me

# --- Redis ---
REDIS_PORT=6379

# --- App ---
DEBUG=true
#CACHE=false

# --- S3 / object storage (Tencent COS, Aliyun OSS, MinIO, ...) ---
S3_BUCKET=your-bucket-name
S3_USERNAME=your-access-key-id
S3_PASSWORD=your-secret-access-key
S3_PUBLIC_URL=https://cos.ap-guangzhou.myqcloud.com
